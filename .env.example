# ── Application ────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://tier1user:secret@localhost:5432/assessments

# ── Object Storage (S3 / MinIO) ────────────────────────────────────
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=submissions
STORAGE_PRESIGNED_URL_EXPIRY=3600

# ── Assessment API ─────────────────────────────────────────────────
ASSESSMENT_API_BASE_URL=http://localhost:8000
ASSESSMENT_SERVICE_TOKEN=your-service-token-here

# ── Tier 2 DIFY Workflow ───────────────────────────────────────────
TIER2_WEBHOOK_URL=http://your-dify-instance/v1/workflows/run
TIER2_DIFY_TOKEN=your-dify-api-key-here

# ── Sandbox (Docker) ──────────────────────────────────────────────
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_SECONDS=180
SANDBOX_MEMORY_LIMIT=536870912
SANDBOX_CPU_QUOTA=50000
SANDBOX_WORKING_DIR=/workspace

# ── Checks ────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
SECRET_SCAN_ENABLED=true

# ── Platform Test API Keys ────────────────────────────────────────
# These are injected into the sandbox container during Level 1 evaluation.
# They replace the learner's placeholder .env values at runtime.
# NEVER share these with learners.
PLATFORM_OPENAI_API_KEY=sk-your-platform-openai-key
PLATFORM_ANTHROPIC_API_KEY=sk-ant-your-platform-anthropic-key
PLATFORM_GROQ_API_KEY=your-platform-groq-key
PLATFORM_COHERE_API_KEY=your-platform-cohere-key
PLATFORM_GOOGLE_API_KEY=your-platform-google-key
PLATFORM_MISTRAL_API_KEY=your-platform-mistral-key
